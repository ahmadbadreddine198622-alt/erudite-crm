{
  "name": "WhatsAppConversation",
  "type": "object",
  "properties": {
    "lead_id": {
      "type": "string",
      "description": "Related Lead ID"
    },
    "phone_number": {
      "type": "string",
      "description": "Contact's WhatsApp number"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "pending",
        "resolved"
      ],
      "default": "open"
    },
    "last_message": {
      "type": "string",
      "description": "Preview of latest message"
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time"
    },
    "unread_count": {
      "type": "number",
      "default": 0
    },
    "ai_summary": {
      "type": "string",
      "description": "AI-generated conversation summary"
    },
    "ai_sentiment": {
      "type": "string",
      "enum": [
        "positive",
        "neutral",
        "negative",
        "unknown"
      ],
      "default": "unknown"
    },
    "ai_intent": {
      "type": "string",
      "description": "Detected client intent"
    },
    "ai_urgency": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "urgent"
      ],
      "default": "low"
    },
    "ai_next_action": {
      "type": "string",
      "description": "AI-recommended next action"
    },
    "ai_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "AI-suggested tags"
    },
    "manual_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Manually added tags"
    },
    "assigned_agent": {
      "type": "string",
      "description": "Agent email"
    }
  },
  "required": [
    "lead_id",
    "phone_number"
  ]
}