{
  "name": "DealStakeholder",
  "type": "object",
  "properties": {
    "deal_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "primary_buyer",
        "spouse",
        "parent",
        "child",
        "business_partner",
        "board_member",
        "advisor",
        "agent_of_buyer",
        "legal",
        "financial",
        "influencer"
      ]
    },
    "decision_power": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "sentiment": {
      "type": "string",
      "enum": [
        "champion",
        "supportive",
        "neutral",
        "skeptical",
        "blocker"
      ]
    },
    "sentiment_score": {
      "type": "number",
      "minimum": -1,
      "maximum": 1
    },
    "objections": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "motivations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_engaged_at": {
      "type": "string",
      "format": "date-time"
    },
    "preferred_channel": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "claude_strategy": {
      "type": "string"
    },
    "influence_priority": {
      "type": "number"
    }
  },
  "required": [
    "deal_id",
    "name",
    "role"
  ]
}