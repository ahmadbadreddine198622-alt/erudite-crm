{
  "name": "AircallCall",
  "type": "object",
  "properties": {
    "aircall_id": {
      "type": "string",
      "description": "Unique Aircall or VAPI call ID"
    },
    "source": {
      "type": "string",
      "enum": [
        "aircall",
        "vapi"
      ],
      "default": "aircall",
      "description": "Which platform originated this call"
    },
    "direction": {
      "type": "string",
      "enum": [
        "inbound",
        "outbound"
      ]
    },
    "status": {
      "type": "string",
      "description": "Call status: done, missed, voicemail, busy, ringing, in-progress, initiated, ended"
    },
    "duration": {
      "type": "number",
      "description": "Duration in seconds"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time"
    },
    "from_number": {
      "type": "string"
    },
    "to_number": {
      "type": "string"
    },
    "aircall_line_name": {
      "type": "string",
      "description": "Aircall line / number name"
    },
    "agent_name": {
      "type": "string"
    },
    "agent_email": {
      "type": "string"
    },
    "recording_url": {
      "type": "string"
    },
    "voicemail_url": {
      "type": "string"
    },
    "transcript": {
      "type": "string"
    },
    "lead_id": {
      "type": "string",
      "description": "Matched Lead ID"
    },
    "landlord_id": {
      "type": "string",
      "description": "Matched Landlord ID"
    },
    "lead_name": {
      "type": "string",
      "description": "Cached lead name"
    },
    "notes": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "aircall_id",
    "direction"
  ]
}