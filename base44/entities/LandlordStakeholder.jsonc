{
  "name": "LandlordStakeholder",
  "type": "object",
  "properties": {
    "landlord_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "spouse",
        "business_partner",
        "lawyer",
        "financial_advisor",
        "child",
        "parent",
        "property_manager",
        "company_director",
        "trustee"
      ],
      "default": "spouse"
    },
    "decision_power": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Influence percentage"
    },
    "sentiment": {
      "type": "string",
      "enum": [
        "champion",
        "supportive",
        "neutral",
        "skeptical",
        "blocker"
      ],
      "default": "neutral"
    },
    "sentiment_score": {
      "type": "number",
      "minimum": -1,
      "maximum": 1
    },
    "last_engaged_at": {
      "type": "string",
      "format": "date-time"
    },
    "preferred_channel": {
      "type": "string",
      "enum": [
        "phone",
        "whatsapp",
        "email",
        "in_person"
      ]
    },
    "language": {
      "type": "string",
      "enum": [
        "en",
        "ar",
        "ru",
        "zh",
        "hi"
      ]
    },
    "claude_strategy": {
      "type": "string",
      "description": "How to influence this person"
    }
  },
  "required": [
    "landlord_id",
    "name",
    "role"
  ]
}